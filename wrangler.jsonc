{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "getting-out-of-the-way-book",
  "main": "worker.js",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/subscribe"]
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}